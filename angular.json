            "scripts": [],
            "extraWebpackConfig": "projects/login-remote/webpack.config.js",
            "commonChunk": false,
            "aot": true
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
